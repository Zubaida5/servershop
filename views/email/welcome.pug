extends baseEmail

block content
  p Hi #{firstName},
  p Welcome to Server Shop, we're glad to have you 
  p We're all a big family here, so make sure to upload your user photo so we get to know you a bit better!
  table.btn.btn-primary(role='presentation', border='0', cellpadding='0', cellspacing='0')
    tbody
      tr
        td(align='left')
          table(role='presentation', border='0', cellpadding='0', cellspacing='0')
            tbody
              tr
                td
                  a(href=`${url}`, target='_blank') Go to your profile
  p If you need any help with Server Shop, please don't hesitate to contact us!
  p - Server Shop Team